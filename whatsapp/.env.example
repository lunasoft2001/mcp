# Prefijo de país por defecto para normalizar números sin código internacional
# Ejemplo: 34 para España, 43 para Austria, 49 para Alemania
# Código de país por defecto para normalizar números de teléfono locales (sin prefijo internacional).
# Ejemplos: 34 (España), 43 (Austria), 49 (Alemania), 1 (USA/Canadá), 44 (UK)
# IMPORTANTE: cámbialo al país donde viven la mayoría de tus contactos.
# Si un número ya incluye el código de país (+43..., 0043...) se usa tal cual.
DEFAULT_COUNTRY_CODE=34

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info

# Carpeta donde se guarda la sesión de WhatsApp (para no reescanear QR cada vez)
WA_SESSION_PATH=./.wwebjs_auth

# Nombre de la sesión (útil si quieres múltiples sesiones)
WA_SESSION_NAME=mcp-session

# Tiempo máximo (ms) esperando a que WhatsApp esté listo antes de rechazar ops
WA_READY_TIMEOUT_MS=30000
