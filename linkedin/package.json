{
  "name": "linkedin-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server para LinkedIn API - publicar posts y leer perfil desde Claude",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "auth": "node dist/auth/oauth-flow.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
