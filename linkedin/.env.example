# Variables de entorno para LinkedIn MCP Server
# Copia este archivo como .env y rellena los valores

# ─── CREDENCIALES DE TU APP LINKEDIN ──────────────────────────────────────────
# Obtén estos valores en https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=tu_client_id_aqui
LINKEDIN_CLIENT_SECRET=tu_client_secret_aqui

# ─── TOKEN DE ACCESO (se genera automáticamente con 'npm run auth') ────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
# LINKEDIN_REFRESH_TOKEN=   # Solo si LinkedIn devuelve refresh token
